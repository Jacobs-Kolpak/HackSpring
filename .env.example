# ============================================================
#  HackSpring — Единый конфиг проекта
#  Скопируй в .env и заполни значения:  cp .env.example .env
# ============================================================

# ── Приложение ──────────────────────────────────────────────
APP_NAME=HackSpring
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── База данных (PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://authkeyhub:authkeyhub_secret@localhost:5432/authkeyhub

# ── JWT / Auth ─────────────────────────────────────────────
SECRET_KEY=change-me-to-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM (провайдер для генерации) ─────────────────────────
#  Поддерживаемые провайдеры: openai | yandexgpt | gigachat | ollama
LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── RAG (Retrieval-Augmented Generation) ───────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_VECTOR_STORE_PATH=./data/vector_store
RAG_TOP_K=5

# ── Audio Summary (TTS / генерация аудио) ──────────────────
#  Движки: silero | piper | edge-tts | openai
TTS_ENGINE=silero
TTS_MODEL=v4_ru
TTS_SPEAKER=baya
TTS_SAMPLE_RATE=48000
TTS_OUTPUT_DIR=./data/audio

# ── Загрузка файлов ────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.csv,.xlsx
UPLOAD_DIR=./data/uploads

# ── Логирование ────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s
