# ============================================================
#  HackSpring — Единый конфиг проекта
#  Скопируй в .env и заполни значения:  cp .env.example .env
# ============================================================

# ── Приложение ──────────────────────────────────────────────
APP_NAME=HackSpring
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── База данных (PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://authkeyhub:authkeyhub_secret@localhost:5432/authkeyhub

# ── JWT / Auth ─────────────────────────────────────────────
SECRET_KEY=change-me-to-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM (генерация ответов) ───────────────────────────────
LLM_PROVIDER=openai
LLM_API_KEY=hackaton2026
LLM_MODEL=gpt-oss-20b
LLM_BASE_URL=https://hackai.centrinvest.ru:6630
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── RAG (Retrieval-Augmented Generation) ───────────────────
#  Chunking
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=180
#  Embeddings (отдельный эндпоинт от LLM)
RAG_EMBEDDINGS_MODEL=Qwen3-Embedding-0.6B
RAG_EMBEDDER_URL=https://hackai.centrinvest.ru:6620
RAG_EMBEDDER_API_KEY=hackaton2026
#  Vector store
RAG_VECTOR_STORE_PATH=./data/vector_store
RAG_COLLECTION=docs_ci
#  Retrieval
RAG_TOP_K=5
RAG_FETCH_K=40
RAG_MIN_SCORE=0.20
RAG_DENSE_WEIGHT=0.70
#  Rerank (опционально, если пусто — не используется)
RAG_RERANK_BLEND=0.35
RAG_RERANK_URL=
RAG_RERANK_API_KEY=
RAG_RERANK_MODEL=

# ── Audio Summary (TTS / генерация аудио) ──────────────────
#  Движки: silero | piper | edge-tts | openai
TTS_ENGINE=silero
TTS_MODEL=v4_ru
TTS_SPEAKER=baya
TTS_SAMPLE_RATE=48000
TTS_OUTPUT_DIR=./data/audio

# ── Загрузка файлов ────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.csv,.xlsx
UPLOAD_DIR=./data/uploads

# ── Логирование ────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s
